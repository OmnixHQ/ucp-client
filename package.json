{
  "name": "@momentum/ucp-client-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run build --workspace=packages/ucp-client",
    "test": "npm run test --workspace=packages/ucp-client",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write '**/*.{ts,json,md}'",
    "format:check": "prettier --check '**/*.{ts,json,md}'",
    "typecheck": "tsc --noEmit --project packages/ucp-client/tsconfig.json",
    "check:comments": "bash scripts/no-descriptive-comments.sh",
    "check:schemas": "bash scripts/validate-schema-coverage.sh",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  }
}
